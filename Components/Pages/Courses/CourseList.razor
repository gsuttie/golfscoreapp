@page "/courses"
@using Microsoft.AspNetCore.Authorization
@using GolfScorer.Models
@using GolfScorer.Services
@attribute [Authorize]
@inject CourseService CourseService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>My Courses</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>My Courses</h1>
    <a href="/courses/new" class="btn btn-primary">Add Course</a>
</div>

@if (courses == null)
{
    <p>Loading...</p>
}
else if (!courses.Any())
{
    <div class="alert alert-info">
        <p>You haven't added any courses yet.</p>
        <a href="/courses/new" class="btn btn-primary">Add Your First Course</a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Course Name</th>
                    <th>Par</th>
                    <th>Holes</th>
                    <th>Slope</th>
                    <th>Rating</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var course in courses)
                {
                    <tr>
                        <td>@course.Name</td>
                        <td>@course.Par</td>
                        <td>@course.NumberOfHoles</td>
                        <td>@(course.SlopeRating?.ToString("F1") ?? "-")</td>
                        <td>@(course.CourseRating?.ToString("F1") ?? "-")</td>
                        <td>
                            <a href="/courses/edit/@course.Id" class="btn btn-sm btn-outline-primary me-1">Edit</a>
                            @if (deleteConfirmId == course.Id)
                            {
                                <button class="btn btn-sm btn-danger me-1" @onclick="() => ConfirmDelete(course.Id)">Confirm</button>
                                <button class="btn btn-sm btn-secondary" @onclick="CancelDelete">Cancel</button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ShowDeleteConfirm(course.Id)">Delete</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<Course>? courses;
    private string? userId;
    private int? deleteConfirmId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (userId != null)
        {
            courses = await CourseService.GetUserCoursesAsync(userId);
        }
    }

    private void ShowDeleteConfirm(int id)
    {
        deleteConfirmId = id;
    }

    private void CancelDelete()
    {
        deleteConfirmId = null;
    }

    private async Task ConfirmDelete(int id)
    {
        if (userId != null)
        {
            await CourseService.DeleteCourseAsync(id, userId);
            deleteConfirmId = null;
            courses = await CourseService.GetUserCoursesAsync(userId);
        }
    }
}
