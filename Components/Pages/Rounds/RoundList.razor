@page "/rounds"
@using Microsoft.AspNetCore.Authorization
@using GolfScorer.Models
@using GolfScorer.Services
@attribute [Authorize]
@inject RoundService RoundService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>My Rounds</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>My Rounds</h1>
    <a href="/rounds/new" class="btn btn-primary">Record Round</a>
</div>

@if (rounds == null)
{
    <p>Loading...</p>
}
else if (!rounds.Any())
{
    <div class="alert alert-info">
        <p>You haven't recorded any rounds yet.</p>
        <a href="/rounds/new" class="btn btn-primary">Record Your First Round</a>
    </div>
}
else
{
    <div class="mb-3">
        <label class="form-label me-2">Filter by year:</label>
        <select class="form-select d-inline-block w-auto" @onchange="OnYearChanged">
            <option value="">All Years</option>
            @foreach (var y in availableYears)
            {
                <option value="@y" selected="@(y == selectedYear)">@y</option>
            }
        </select>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Date</th>
                    <th>Course</th>
                    <th>Score</th>
                    <th>+/-</th>
                    <th>Putts</th>
                    <th>GIRs</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var round in rounds)
                {
                    var scoreToPar = round.TotalScore - (round.Course?.Par ?? 72);
                    var scoreClass = scoreToPar < 0 ? "text-success" : scoreToPar > 0 ? "text-danger" : "";
                    <tr>
                        <td>@round.DatePlayed.ToString("MMM d, yyyy")</td>
                        <td>@(round.Course?.Name ?? "Unknown")</td>
                        <td><strong>@round.TotalScore</strong></td>
                        <td class="@scoreClass">
                            @(scoreToPar > 0 ? $"+{scoreToPar}" : scoreToPar.ToString())
                        </td>
                        <td>@round.TotalPutts</td>
                        <td>@round.GIRCount / @(round.Course?.NumberOfHoles ?? 18)</td>
                        <td>
                            <a href="/rounds/@round.Id" class="btn btn-sm btn-outline-primary me-1">View</a>
                            <a href="/rounds/edit/@round.Id" class="btn btn-sm btn-outline-secondary me-1">Edit</a>
                            @if (deleteConfirmId == round.Id)
                            {
                                <button class="btn btn-sm btn-danger me-1" @onclick="() => ConfirmDelete(round.Id)">Confirm</button>
                                <button class="btn btn-sm btn-secondary" @onclick="CancelDelete">Cancel</button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ShowDeleteConfirm(round.Id)">Delete</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-3 text-muted">
        Showing @rounds.Count round(s)
    </div>
}

@code {
    private List<Round>? rounds;
    private string? userId;
    private int? selectedYear;
    private List<int> availableYears = new();
    private int? deleteConfirmId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (userId != null)
        {
            // Default to current year
            selectedYear = DateTime.Now.Year;
            await LoadRounds();

            // Get available years for filter
            var allRounds = await RoundService.GetRoundsAsync(userId);
            availableYears = allRounds.Select(r => r.DatePlayed.Year).Distinct().OrderByDescending(y => y).ToList();
        }
    }

    private async Task LoadRounds()
    {
        if (userId != null)
        {
            rounds = await RoundService.GetRoundsAsync(userId, selectedYear);
        }
    }

    private async Task OnYearChanged(ChangeEventArgs e)
    {
        selectedYear = string.IsNullOrEmpty(e.Value?.ToString()) ? null : int.Parse(e.Value.ToString()!);
        await LoadRounds();
    }

    private void ShowDeleteConfirm(int id)
    {
        deleteConfirmId = id;
    }

    private void CancelDelete()
    {
        deleteConfirmId = null;
    }

    private async Task ConfirmDelete(int id)
    {
        if (userId != null)
        {
            await RoundService.DeleteRoundAsync(id, userId);
            deleteConfirmId = null;
            await LoadRounds();
        }
    }
}
